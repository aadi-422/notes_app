# Copy these into Render Dashboard → notes-api → Environment
# (Do not commit real secrets; Render generates JWT_SECRET via render.yaml)

SPRING_PROFILES_ACTIVE=postgres

# Set in Render UI (required for /about assignment)
ABOUT_NAME=Your Name
ABOUT_EMAIL=you@example.com

# Injected automatically when using render.yaml + notes-db database:
# DATABASE_URL=postgresql://notes_user:...@.../notes_db

# Optional overrides (usually not needed on Render)
JWT_EXPIRATION_MS=86400000
# PORT is set automatically by Render
