# Server
PORT=8080

# Profile: sqlite (default, local) or postgres (production)
SPRING_PROFILES_ACTIVE=sqlite

# JWT (required in production — at least 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MS=86400000

# SQLite (local development)
SQLITE_PATH=./data/notes.db

# PostgreSQL (production)
DATABASE_URL=jdbc:postgresql://localhost:5432/notes_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# About endpoint
ABOUT_NAME=Your Name
ABOUT_EMAIL=you@example.com

# --- Render production: use .env.render.example + DEPLOY_RENDER.md ---
# Do not use SQLite on Render. Blueprint sets DATABASE_URL from Postgres automatically.
